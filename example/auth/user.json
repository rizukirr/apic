{
    "name": "current-user",
    "description": "Current authenticated user",
    "method": "GET",
    "url": {
        "protocol": "https",
        "host": "api.example.com",
        "path": ["auth", "user"]
    },
    "headers": [
        {
            "name": "Content-Type",
            "value": "application/json"
        },
        {
            "name": "Authorization",
            "value": "Bearer {token}"
        }
    ],
    "responses": [
        {
            "code": 200,
            "description": "success",
            "example": {
                "status": 200,
                "message": "OK",
                "data": {
                    "id": 1,
                    "name": "Rizki Rakasiwi",
                    "email": "rizki@example.com"
                }
            },
            "schema": [
                {
                    "name": "status",
                    "type": "int",
                    "default": "200",
                    "description": "Status code",
                    "required": true,
                    "properties": null
                },
                {
                    "name": "message",
                    "type": "string",
                    "default": null,
                    "description": "Message",
                    "required": true,
                    "properties": null
                },
                {
                    "name": "data",
                    "type": "object",
                    "default": null,
                    "description": "Data",
                    "required": false,
                    "properties": [
                        {
                            "name": "id",
                            "type": "int",
                            "default": null,
                            "description": "User ID",
                            "required": true
                        },
                        {
                            "name": "name",
                            "type": "string",
                            "default": null,
                            "description": "User name",
                            "required": true
                        },
                        {
                            "name": "email",
                            "type": "string",
                            "default": null,
                            "description": "User email",
                            "required": true
                        }
                    ]
                }
            ]
        },
        {
            "code": 401,
            "description": "Missing or expired token",
            "example": {
                "status": 401,
                "message": "Missing or expired token",
                "data": null
            },
            "schema": [
                {
                    "name": "status",
                    "type": "int",
                    "default": "401",
                    "description": "Status code",
                    "required": true,
                    "properties": null
                },
                {
                    "name": "message",
                    "type": "string",
                    "default": null,
                    "description": "Message",
                    "required": true,
                    "properties": null
                },
                {
                    "name": "data",
                    "type": "object",
                    "default": null,
                    "description": "Data",
                    "required": false,
                    "properties": null
                }
            ]
        }
    ]
}
