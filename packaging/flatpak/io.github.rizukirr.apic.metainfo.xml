<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.rizukirr.apic</id>
  <name>apic</name>
  <summary>Design and review API contracts as plain JSON</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <developer id="io.github.rizukirr">
    <name>Rizki Rakasiwi</name>
  </developer>
  <description>
    <p>
      apic stores your API contracts as plain JSON in your repository, so they
      are diffable, reviewable, and versioned like the rest of your code.
    </p>
    <p>
      The desktop app opens a project folder and lets you browse, read, edit,
      and repair contracts with a graphical interface, sharing the same engine
      as the apic CLI and TUI.
    </p>
  </description>
  <launchable type="desktop-id">io.github.rizukirr.apic.desktop</launchable>
